DATABASE_URL="postgresql://rfi:rfi@localhost:5432/rfi_engine?schema=public"
JWT_SECRET="change-me-in-production-this-should-be-32-bytes-of-random"
PORT=4000
NODE_ENV=development

# LLM (used by both agents and the subjective evaluator). Optional in dev — falls back to template.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Storage. Use "local" for dev, "r2" for cloud demo. R2 fields only required when STORAGE_PROVIDER=r2.
STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=./uploads
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# CORS / invitation links
CORS_ORIGIN=http://localhost:5173
PUBLIC_FRONTEND_URL=http://localhost:5173
INVITATION_TTL_DAYS=7
MAX_UPLOAD_BYTES=10485760
